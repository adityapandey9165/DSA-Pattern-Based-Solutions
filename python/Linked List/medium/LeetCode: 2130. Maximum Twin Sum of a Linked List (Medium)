# Quick tests for local verification
# -----------------------
if __name__ == "__main__":
    class ListNode:
        def __init__(self, val=0, next=None):
            self.val = val
            self.next = next

    def build_list(vals):
        dummy = ListNode(0)
        cur = dummy
        for v in vals:
            cur.next = ListNode(v)
            cur = cur.next
        return dummy.next

    sol = Solution()

    head = build_list([5, 4, 2, 1])
    print(sol.pairSum(head))  # Expected: 6

    head = build_list([4, 2, 2, 3])
    print(sol.pairSum(head))  # Expected: 7

    head = build_list([1, 100000])
    print(sol.pairSum(head))  # Expected: 100001
