# Quick tests for local verification
# -----------------------
if __name__ == "__main__":
    sol = Solution()

    print(sol.findThePrefixCommonArray([1,3,2,4], [3,1,2,4]))
    # Expected: [0,2,3,4]

    print(sol.findThePrefixCommonArray([2,3,1], [3,1,2]))
    # Expected: [0,1,3]
